{
  "name": "landing",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/landing/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/landing",
        "browser": "apps/landing/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/landing/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/landing/public"
          }
        ],
        "styles": ["apps/landing/src/tailwind.css", "apps/landing/src/styles.scss"],
        "prerender": {
          "routesFile": "apps/landing/routes.txt"
        },
        "server": "apps/landing/src/main.server.ts",
        "ssr": {
          "entry": "apps/landing/src/server.ts"
        },
        "outputMode": "static"
      },
      "configurations": {
        "staging": {
          "fileReplacements": [
            {
              "replace": "apps/landing/src/environments/environment.ts",
              "with": "apps/landing/src/environments/environment.staging.ts"
            }
          ],
          "outputHashing": "all"
        },
        "production": {
          "fileReplacements": [
            {
              "replace": "apps/landing/src/environments/environment.ts",
              "with": "apps/landing/src/environments/environment.prod.ts"
            }
          ],
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1.5mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "12kb",
              "maximumError": "24kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "landing:build:production"
        },
        "development": {
          "buildTarget": "landing:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "landing:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "landing:build",
        "port": 4200,
        "staticFilePath": "dist/apps/landing/browser",
        "spa": true
      }
    }
  }
}
