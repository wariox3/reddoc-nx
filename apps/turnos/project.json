{
  "name": "turnos",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/turnos/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/turnos",
        "browser": "apps/turnos/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/turnos/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/turnos/public"
          },
          {
            "glob": "*.woff2",
            "input": "node_modules/geist/dist/fonts/geist-sans",
            "output": "fonts/geist"
          },
          {
            "glob": "logos/**",
            "input": "libs/ui/src/assets",
            "output": "/"
          }
        ],
        "styles": ["apps/turnos/src/tailwind.css", "apps/turnos/src/styles.scss"]
      },
      "configurations": {
        "staging": {
          "fileReplacements": [
            {
              "replace": "apps/turnos/src/environments/environment.ts",
              "with": "apps/turnos/src/environments/environment.staging.ts"
            }
          ],
          "outputHashing": "all"
        },
        "production": {
          "fileReplacements": [
            {
              "replace": "apps/turnos/src/environments/environment.ts",
              "with": "apps/turnos/src/environments/environment.prod.ts"
            }
          ],
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1.5mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "12kb",
              "maximumError": "24kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "options": {
        "port": 4206
      },
      "configurations": {
        "production": {
          "buildTarget": "turnos:build:production"
        },
        "development": {
          "buildTarget": "turnos:build:development",
          "proxyConfig": "apps/turnos/proxy.conf.json"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "turnos:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/turnos/jest.config.ts",
        "tsConfig": "apps/turnos/tsconfig.spec.json"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "turnos:build",
        "port": 4206,
        "staticFilePath": "dist/apps/turnos/browser",
        "spa": true
      }
    }
  }
}
